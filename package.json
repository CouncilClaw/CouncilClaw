{
  "name": "councilclaw",
  "version": "0.1.0",
  "private": true,
  "description": "CouncilClaw: Multi-model deliberation, single-agent execution.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "npm run typecheck && npm run test && npm run build",
    "dev:server": "COUNCILCLAW_MODE=server tsx src/index.ts",
    "cli": "tsx src/cli/main.ts",
    "setup": "tsx src/cli/main.ts configure",
    "chat": "tsx src/cli/main.ts chat",
    "models": "tsx src/cli/main.ts models",
    "config": "tsx src/cli/main.ts config",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  },
  "bin": {
    "councilclaw": "dist/cli/main.js"
  },
  "license": "GPL-3.0-only"
}
